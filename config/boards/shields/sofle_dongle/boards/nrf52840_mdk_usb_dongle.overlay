#include <dt-bindings/zmk/matrix_transform.h>

/ {

	chosen {
		zmk,kscan = &kscan0;
	};

	kscan0: kscan {
		compatible = "zmk,kscan-gpio-direct";
		label = "KSCAN";
		input-gpios
		= <&gpio0 10 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
		;
	};

};

nice_view_spi: &spi0 {
    status = "disabled";
}

pro_micro_i2c: &i2c0 {
    status = "disabled";
};